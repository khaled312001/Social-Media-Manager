# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000
APP_NAME=Barmagly

# ─── Database ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://barmagly:barmagly_dev_secret@localhost:5432/barmagly

# ─── Redis ────────────────────────────────────────────────────────
REDIS_URL=redis://:barmagly_redis_secret@localhost:6379

# ─── Elasticsearch ────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=barmagly_es_secret

# ─── JWT ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_minimum_32_characters_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_minimum_32_chars
JWT_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── Encryption (for social tokens at rest) ───────────────────────
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your_32_byte_hex_encryption_key_here

# ─── Stripe ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Anthropic (AI) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Email (Resend) ───────────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@barmagly.com
EMAIL_FROM_NAME=Barmagly

# ─── Storage (AWS S3 / MinIO) ─────────────────────────────────────
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=barmagly-media
# For local MinIO:
# AWS_ENDPOINT=http://localhost:9000
# AWS_S3_FORCE_PATH_STYLE=true

# ─── Social: Facebook / Instagram ─────────────────────────────────
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret
FACEBOOK_CALLBACK_URL=http://localhost:3001/auth/oauth/facebook/callback

# ─── Social: Twitter / X ─────────────────────────────────────────
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_CALLBACK_URL=http://localhost:3001/auth/oauth/twitter/callback

# ─── Social: TikTok ───────────────────────────────────────────────
TIKTOK_APP_ID=your_tiktok_app_id
TIKTOK_APP_SECRET=your_tiktok_app_secret
TIKTOK_CALLBACK_URL=http://localhost:3001/auth/oauth/tiktok/callback

# ─── Social: LinkedIn ─────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=http://localhost:3001/auth/oauth/linkedin/callback

# ─── Social: YouTube / Google ────────────────────────────────────
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_CALLBACK_URL=http://localhost:3001/auth/oauth/youtube/callback

# ─── Sentry (Error Tracking) ──────────────────────────────────────
SENTRY_DSN=https://...@sentry.io/...

# ─── Rate Limiting ────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── CORS ─────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
